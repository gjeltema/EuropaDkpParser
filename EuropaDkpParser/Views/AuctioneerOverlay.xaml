<UserControl x:Class="EuropaDkpParser.Views.AuctioneerOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EuropaDkpParser.Views"
             xmlns:viewmodels="clr-namespace:EuropaDkpParser.ViewModels" 
             d:DataContext="{d:DesignInstance Type=viewmodels:AuctioneerOverlayViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Visibility="{Binding DisplayControls, Converter={StaticResource BoolToVisibilityConverter}}">
        <WrapPanel Orientation="Vertical">
            <!-- ActiveAuctions -->
            <ListView x:Name="ActiveAuctionListing" ItemsSource="{Binding ActiveAuctions}" SelectedItem="{Binding SelectedActiveAuction}" 
                Margin="0,0,0,5" Height="150" Width="380" Background="Transparent" BorderBrush="Transparent" BorderThickness="0">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Path=Auctioneer}" Value="You">
                                <Setter Property="Foreground" Value="{StaticResource BidTrackingForegroundOkBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Path=HasNewBidsAdded}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource BidTrackingForegroundAlertBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>

            <!-- Buttons -->
            <WrapPanel>
                <Button Content="{StaticResource SetAuctionToCompleted}" Command="{Binding SetActiveAuctionToCompletedCommand}" 
                    HorizontalAlignment="Right" Width="110" Height="30" Margin="0,0,25,15" Opacity=".7"/>

                <Button Grid.Column="1" Content="{Binding CurrentStatusMarker}" Command="{Binding CycleToNextStatusMarkerCommand}" 
                    HorizontalAlignment="Right" VerticalAlignment="Top" Width="50" Height="30" Margin="0,0,5,0" Opacity=".7"/>

                <Button Grid.Column="2" Content="{StaticResource CopyText}" Command="{Binding CopySelectedStatusMessageToClipboardCommand}" 
                    HorizontalAlignment="Right" VerticalAlignment="Top" Width="85" Height="30" Margin="0,0,0,0" Opacity=".7"/>
            </WrapPanel>

            <!-- SPENT calls -->
            <ListView ItemsSource="{Binding SpentMessagesToPaste}" SelectedItem="{Binding SelectedSpentMessageToPaste}"
                      Height="90" Width="300" Background="Transparent" BorderBrush="Transparent" BorderThickness="0">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Path=SpentCallSent}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource BidTrackingForegroundOkBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>

            <Button Content="{StaticResource CopyText}" Command="{Binding CopySelectedSpentCallToClipboardCommand}" 
                    HorizontalAlignment="Right" Width="85" Height="30" Margin="5,5,0,0" Opacity=".7"/>
        </WrapPanel>
    </Grid>
</UserControl>
