<UserControl x:Class="EuropaDkpParser.Views.AuctioneerOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EuropaDkpParser.Views"
             xmlns:viewmodels="clr-namespace:EuropaDkpParser.ViewModels" 
             d:DataContext="{d:DesignInstance Type=viewmodels:AuctioneerOverlayViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Visibility="{Binding DisplayControls, Converter={StaticResource BoolToVisibilityConverter}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- ActiveAuctions -->
            <ListView Grid.Row="0" x:Name="ActiveAuctionListing" ItemsSource="{Binding ActiveAuctions}" SelectedItem="{Binding SelectedActiveAuction}" 
                Margin="0,0,0,5" Background="Transparent" BorderBrush="#55101010" BorderThickness="1">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Path=Auctioneer}" Value="You">
                                <Setter Property="Foreground" Value="{StaticResource BidTrackingForegroundOkBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Path=HasNewBidsAdded}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource BidTrackingForegroundAlertBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>

            <!-- Buttons -->
        <Grid Grid.Row="1" Margin="0,5,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="0" Content="{StaticResource SetAuctionToCompleted}" Command="{Binding SetActiveAuctionToCompletedCommand}" 
                    HorizontalAlignment="Left" Width="110" Height="30" Opacity=".7"/>

                <Button Grid.Column="1" Content="{Binding CurrentStatusMarker}" Command="{Binding CycleToNextStatusMarkerCommand}" 
                    VerticalAlignment="Top" Width="50" Height="30" Margin="0,0,5,0" Opacity=".7"/>

                <Button Grid.Column="2" Content="{StaticResource CopyText}" Command="{Binding CopySelectedStatusMessageToClipboardCommand}" 
                    VerticalAlignment="Top" Width="85" Height="30" Opacity=".7"/>
            </Grid>

            <!-- SPENT calls -->
            <ListView Grid.Row="2" ItemsSource="{Binding SpentMessagesToPaste}" SelectedItem="{Binding SelectedSpentMessageToPaste}"
                       Background="Transparent" BorderBrush="#55101010" BorderThickness="1">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Path=SpentCallSent}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource BidTrackingForegroundOkBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>

        <Button Grid.Row="3" Content="{StaticResource CopyText}" Command="{Binding CopySelectedSpentCallToClipboardCommand}" 
                    HorizontalAlignment="Right" Width="85" Height="30" Margin="0,5,0,0" Opacity=".7"/>
    </Grid>
</UserControl>
