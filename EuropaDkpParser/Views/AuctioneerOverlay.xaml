<UserControl x:Class="EuropaDkpParser.Views.AuctioneerOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EuropaDkpParser.Views"
             xmlns:viewmodels="clr-namespace:EuropaDkpParser.ViewModels" 
             d:DataContext="{d:DesignInstance Type=viewmodels:AuctioneerOverlayViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ActiveAuctions -->
        <ListView Grid.Row="0" x:Name="ActiveAuctionListing" Opacity="0.5" ItemsSource="{Binding ActiveAuctions}" SelectedItem="{Binding SelectedActiveAuction}" 
                BorderBrush="#55101010" BorderThickness="1">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Path=Auctioneer}" Value="You">
                            <Setter Property="Foreground" Value="{StaticResource BidTrackingForegroundOkBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Path=HasNewBidsAdded}" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource BidTrackingForegroundAlertBrush}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <!-- Buttons -->
        <Grid Grid.Row="1" Margin="0,5,0,5" Opacity="0.7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="{StaticResource SetAllAuctionsToCompleted}" Command="{Binding SetAllAuctionsToCompletedCommand}" 
                    Width="120" Height="30" HorizontalAlignment="Left"/>
            
            <Button Grid.Column="1" Content="{StaticResource SetAuctionToCompleted}" Command="{Binding SetActiveAuctionToCompletedCommand}" 
                    Width="120" Height="30" Margin="5,0,0,0" HorizontalAlignment="Left"/>

            <Button Grid.Column="3" Content="{Binding CurrentStatusMarker}" Command="{Binding CycleToNextStatusMarkerCommand}" 
                    Width="50" Height="30" HorizontalAlignment="Right" Margin="0,0,5,0"/>

            <Button Grid.Column="4" Content="{StaticResource CopyStatusText}" Command="{Binding CopySelectedStatusMessageToClipboardCommand}" 
                    Width="100" Height="30" HorizontalAlignment="Right"/>
        </Grid>

        <!-- SPENT calls -->
        <ListView Grid.Row="2" Opacity="0.5" ItemsSource="{Binding SpentMessagesToPaste}" SelectedItem="{Binding SelectedSpentMessageToPaste}"
                       BorderBrush="#55101010" BorderThickness="1">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Path=RaidAttendanceBelowThreshold}" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource BidTrackingForegroundAlertBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Path=SpentCallSent}" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource BidTrackingForegroundOkBrush}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <Button Grid.Row="3" Content="{StaticResource CopySpentText}" Command="{Binding CopySelectedSpentCallToClipboardCommand}" 
                    HorizontalAlignment="Right" Width="100" Height="30" Margin="0,5,0,0" Opacity=".7"/>
    </Grid>
</UserControl>
